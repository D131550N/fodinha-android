<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutTruco"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B8E3C"
    tools:ignore="RtlSymmetry,HardcodedText">

    <!-- A Mesa de Jogo (Onde a mágica das cartas acontece no Java) -->
    <me.chester.minitruco.android.MesaView
        android:id="@+id/MesaView01"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- CAIXA DE PALPITE (Fica invisível até ser a sua vez) -->
    <LinearLayout
        android:id="@+id/layoutPalpite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="120dp"
        android:background="#E6000000"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"> <!-- O Java vai mudar para VISIBLE na sua vez -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Quantas você faz?"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMenosPalpite"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="-"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvValorPalpite"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMaisPalpite"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="+"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmaPalpite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Confirmar"
            android:textStyle="bold"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnNovaPartida"
        android:layout_width="200sp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:onClick="novaPartidaClickHandler"
        android:visibility="gone"
        android:text="Nova Partida" />

</FrameLayout>
