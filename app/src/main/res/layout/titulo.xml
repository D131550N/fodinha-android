<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B8E3C"
    android:gravity="center"
    android:orientation="vertical"
    tools:ignore="RtlSymmetry,HardcodedText,UsingOnClickInXml">

    <ImageView
        android:id="@+id/imgLogoFodinha"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_fodinha" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="48dp">

        <TextView
            android:id="@+id/versao_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fodinha v0.0.1 beta"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Build por Dieisson 👨‍💻\nBaseado no Minitruco de Chester."
            android:gravity="center"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnJogar"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:onClick="jogarClickHandler"
            android:text="👤 JOGAR LOCAL"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnBluetooth"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:onClick="bluetoothClickHandler"
            android:text="🔵 BLUETOOTH"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAjuda"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ajuda"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnSobre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sobre"
                android:layout_marginHorizontal="4dp"/>

            <Button
                android:id="@+id/btnOpcoes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:onClick="opcoesButtonClickHandler"
                android:text="Opções"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
